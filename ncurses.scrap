#!/bin/bash
# DEPENDS: 

echo ">>> Building ncurses (terminal library)..."
wget -q https://invisible-mirror.net/archives/ncurses/ncurses-6.5.tar.gz
tar -xzf ncurses-6.5.tar.gz
cd ncurses-6.5

./configure --prefix=/usr --with-shared --without-debug --enable-widec || exit 1
make -j$(nproc) || exit 1
make install || exit 1

cd ..
rm -rf ncurses-6.5 ncurses-6.5.tar.gz
