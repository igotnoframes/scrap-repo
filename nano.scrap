#!/bin/bash
# DEPENDS: ncurses

echo ">>> Fetching source..."
wget -q https://www.nano-editor.org/dist/v8/nano-8.0.tar.gz
tar -xzf nano-8.0.tar.gz
cd nano-8.0

CONFIG_FLAGS="--prefix=/usr"

if [[ "$USE_FLAGS" == "all" ]]; then
    CONFIG_FLAGS="$CONFIG_FLAGS --enable-utf8 --enable-color --enable-extra"
fi

./configure $CONFIG_FLAGS || exit 1
make -j$(nproc) || exit 1
make install || exit 1

cd ..
rm -rf nano-8.0 nano-8.0.tar.gz
